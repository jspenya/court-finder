<%= form_with url: search_path, method: :post, scope: :search, class: "search-form", data: { action: "turbo:submit-start->search-form#showLoading turbo:submit-end->search-form#hideLoading" } do |form| %>
  <% if search_error.present? %>
    <p class="form__error" role="alert"><%= search_error %></p>
  <% end %>

  <div class="play-window-picker"
       data-controller="play-window-picker"
       data-play-window-picker-min-date-value="<%= Time.zone.today.iso8601 %>">
    <%= form.hidden_field :date,
          value: search_defaults[:date],
          required: true,
          data: { play_window_picker_target: "dateField" } %>
    <%= form.hidden_field :play_time,
          value: search_defaults[:play_time],
          required: true,
          data: { play_window_picker_target: "playTimeField" } %>
    <%= form.hidden_field :play_time_end,
          value: search_defaults[:play_time_end],
          required: true,
          data: { play_window_picker_target: "playTimeEndField" } %>

    <label class="field">
      <span class="field__label">When do you want to play?</span>
      <div class="play-window-picker__control">
        <button type="button"
                class="play-window-picker__trigger"
                data-play-window-picker-target="trigger"
                data-action="click->play-window-picker#toggle"
                aria-haspopup="dialog"
                aria-expanded="false">
          <svg class="play-window-picker__trigger-icon" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <rect x="3" y="4" width="18" height="18" rx="2" />
            <path d="M16 2v4M8 2v4M3 10h18" />
          </svg>
          <span class="play-window-picker__trigger-label" data-play-window-picker-target="triggerLabel"></span>
          <svg class="play-window-picker__trigger-chevron" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
            <path d="M9 6l6 6-6 6" />
          </svg>
        </button>

        <div class="play-window-picker__panel"
             data-play-window-picker-target="panel"
             role="dialog"
             aria-label="Choose play time window"
             hidden>
          <div class="play-window-picker__panel-body">
            <div class="play-window-picker__date">
              <span class="play-window-picker__section-label">Date</span>
              <%= tag.input type: "text",
                    autocomplete: "off",
                    class: "play-window-picker__date-native-input",
                    data: { play_window_picker_target: "dateInput" },
                    value: search_defaults[:date] %>
            </div>

            <div class="play-window-picker__times">
              <div class="play-window-picker__time-field">
                <span class="play-window-picker__section-label">From</span>
              <div class="play-window-picker__time-control">
                <%= tag.input type: "text",
                      autocomplete: "off",
                      data: { play_window_picker_target: "playTimeInput" },
                      value: search_defaults[:play_time] %>
              </div>
              </div>

              <svg class="play-window-picker__times-separator" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                <path d="M9 6l6 6-6 6" />
              </svg>

              <div class="play-window-picker__time-field">
                <span class="play-window-picker__section-label">To</span>
              <div class="play-window-picker__time-control">
                <%= tag.input type: "text",
                      autocomplete: "off",
                      data: { play_window_picker_target: "playTimeEndInput" },
                      value: search_defaults[:play_time_end] %>
              </div>
              </div>
            </div>
          </div>

          <p class="play-window-picker__error" data-play-window-picker-target="error" hidden role="alert"></p>

          <div class="play-window-picker__actions">
            <button type="button"
                    class="button button--ghost play-window-picker__action"
                    data-action="click->play-window-picker#cancel">
              Cancel
            </button>
            <button type="button"
                    class="button button--primary play-window-picker__action"
                    data-action="click->play-window-picker#update">
              Update
            </button>
          </div>
        </div>
      </div>
    </label>
  </div>

  <%= form.submit "Check availability", class: "button button--primary check-availability-button", data: { search_form_target: "submit" } %>
<% end %>
